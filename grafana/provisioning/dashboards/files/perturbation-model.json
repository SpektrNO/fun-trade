        "iconColor": "semi-dark-red",
        "name": "Regime invalid",
        "target": {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH ordered AS (\n  SELECT time,\n         regime_valid,\n         lag(regime_valid) OVER (ORDER BY time) AS prev_rv\n  FROM perturbation_daily\n  WHERE symbol = '$symbol' AND $__timeFilter(time)\n),\nstarts AS (\n  SELECT time,\n         regime_valid,\n         SUM(\n           CASE\n             WHEN regime_valid = false\n              AND (prev_rv IS NULL OR prev_rv = true) THEN 1\n             ELSE 0\n           END\n         ) OVER (ORDER BY time) AS grp\n  FROM ordered\n)\nSELECT\n  MIN(time) AS time,\n  MAX(time) + interval '1 day' AS \"timeEnd\",\n  'Regime invalid — buys blocked' AS text\nFROM starts\nWHERE regime_valid = false\nGROUP BY grp\nORDER BY 1",
          "refId": "Anno"
        }
      }
    ]
  },
