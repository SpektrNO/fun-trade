      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 18 },
      "id": 5,
      "options": { "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TimescaleDB" },
          "format": "table",
          "rawSql": "SELECT executed_at, symbol, side, qty_shares, price, fee_eur, epsilon, regime_valid, signal FROM paper_trades WHERE ('$symbol' = 'All' OR symbol = '$symbol') AND $__timeFilter(executed_at) ORDER BY executed_at DESC LIMIT 100",
          "refId": "A"
        }
      ],
      "title": "Recent Paper Trades ($symbol)",
