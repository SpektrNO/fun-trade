      "id": 3,
      "options": { "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TimescaleDB" },
          "format": "table",
          "rawSql": "SELECT symbol, net_qty_shares, avg_price, updated_at FROM paper_positions WHERE ('$symbol' = 'All' OR symbol = '$symbol') ORDER BY symbol",
          "refId": "A"
        }
      ],
      "title": "Open Positions ($symbol)",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 4,
      "options": { "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TimescaleDB" },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS total_trades, SUM(fee_eur) AS total_fees FROM paper_trades WHERE ('$symbol' = 'All' OR symbol = '$symbol') AND $__timeFilter(executed_at)",
          "refId": "A"
        }
      ],
      "title": "Trade Summary ($symbol)",
