  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "currencyEUR",
          "displayName": "Cumulative cash flow (EUR)"
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TimescaleDB" },
          "format": "time_series",
          "rawSql": "SELECT executed_at AS time, SUM(CASE WHEN side = 'sell' THEN qty_shares * price - fee_eur ELSE -(qty_shares * price + fee_eur) END) OVER (ORDER BY executed_at) AS cumulative_pnl FROM paper_trades WHERE ('$symbol' = 'All' OR symbol = '$symbol') AND $__timeFilter(executed_at) ORDER BY executed_at",
          "refId": "A"
        }
      ],
      "title": "Paper Cumulative Cash Flow ($symbol)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 2,
      "options": { "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TimescaleDB" },
          "format": "table",
          "rawSql": "SELECT cash_eur, realized_pnl, updated_at FROM paper_portfolio WHERE id = 1",
          "refId": "A"
        }
      ],
      "title": "Paper Portfolio",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
