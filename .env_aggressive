# Aggressive preset — copy to .env: cp .env_aggressive .env
# Pair with config_aggressive.json. Copy EOD_API_TOKEN from your existing .env if needed.
# Stance: lower ε bar, shorter H₀ window, weaker macro/trend dampening (more trades).

FUNTRADE_CHART_BACKEND=plotly
FUNTRADE_CONFIG=config_aggressive.json

# Database (port 5433 on host maps to 5432 in container)
DATABASE_URL=postgresql://funtrade:funtrade@localhost:5433/funtrade
POSTGRES_USER=funtrade
POSTGRES_PASSWORD=funtrade
POSTGRES_DB=funtrade

# H0 calibration window (shorter = more reactive fair value; ETF/mutual override in config)
H0_CALIBRATION_DAYS=252
H0_FOURIER_HARMONICS=2

# Model defaults (per-class thresholds live in config_aggressive.json)
EPSILON_THRESHOLD=0.65
REGIME_SPIKE_SIGMA=3.5
REGIME_CONSECUTIVE_BARS=4
MIN_DAILY_VOLUME_EUR=100000

# H0 factor weights (weaker macro drift — ε tracks price moves more closely)
H0_WEIGHT_EUR_RATES=0.08
H0_WEIGHT_CREDIT_SPREAD=0.05
H0_WEIGHT_EUR_USD=0.05
H0_WEIGHT_SECTOR_BETA=-0.05

H0_ENABLE_OIL=true
H0_OIL_TICKER=BZ=F
H0_WEIGHT_OIL=0.05

H0_ENABLE_CLIMATE=true
# spread = clean-energy return minus fossil/oil return; single = one ETF level series
H0_CLIMATE_MODE=spread
H0_CLIMATE_TICKER=INRG.L
H0_CLIMATE_CLEAN_TICKER=INRG.L
H0_CLIMATE_FOSSIL_TICKER=BZ=F
H0_WEIGHT_CLIMATE=0.0

# Trend expectation (H₂)
TREND_ENABLE=true
TREND_LOOKBACK_DAYS=200

# Paper trading
PAPER_INITIAL_CASH_EUR=100000
PAPER_POSITION_LIMIT_SHARES=1000
PAPER_FEE_BPS=5
PAPER_TRADE_SHARES=10
PAPER_CSV_PATH=data/paper_trades.csv

# Backtest
BACKTEST_INITIAL_CASH_EUR=100000
BACKTEST_FEE_BPS=5
BACKTEST_POSITION_LIMIT_SHARES=1000
BACKTEST_TRADE_SHARES=10

# Data providers
STOOQ_ENABLED=true
EOD_API_TOKEN=
RECONCILE_DIFF_THRESHOLD_BPS=10
