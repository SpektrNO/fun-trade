# Database (host port 5433 → container 5432)
DATABASE_URL=postgresql://funtrade:funtrade@localhost:5433/funtrade
POSTGRES_USER=funtrade
POSTGRES_PASSWORD=funtrade
POSTGRES_DB=funtrade

# Universe — watchlists, aliases, and per-asset-class model params live in config.json
# Optional override path (default: ./config.json at repo root)
# FUNTRADE_CONFIG=config.json

# H0 calibration window (days of price history; avoids stale/trend-blown μ on long series)
H0_CALIBRATION_DAYS=504
# Annual Fourier harmonics in H₀ seasonality (smooth month transitions; default 2)
H0_FOURIER_HARMONICS=2

# H0 factor weights (core macro — always active)
H0_WEIGHT_EUR_RATES=0.15
H0_WEIGHT_CREDIT_SPREAD=0.10
H0_WEIGHT_EUR_USD=0.10
H0_WEIGHT_SECTOR_BETA=-0.10

# Optional H0 factors (off by default; enable and run `make ingest-factors`)
H0_ENABLE_OIL=false
H0_OIL_TICKER=BZ=F
H0_WEIGHT_OIL=-0.08

H0_ENABLE_CLIMATE=false
# spread = clean-energy return minus fossil/oil return; single = one ETF level series
H0_CLIMATE_MODE=spread
H0_CLIMATE_TICKER=INRG.L
H0_CLIMATE_CLEAN_TICKER=INRG.L
H0_CLIMATE_FOSSIL_TICKER=BZ=F
H0_WEIGHT_CLIMATE=0.06

# Trend expectation (H₂ — global on/off; per-class weights in config.json)
TREND_ENABLE=false
TREND_LOOKBACK_DAYS=200

# Paper trading
PAPER_INITIAL_CASH_EUR=100000
PAPER_POSITION_LIMIT_SHARES=1000
PAPER_FEE_BPS=5
PAPER_TRADE_SHARES=10
PAPER_CSV_PATH=data/paper_trades.csv

# Backtest (defaults to paper wallet size if BACKTEST_INITIAL_CASH_EUR unset)
BACKTEST_INITIAL_CASH_EUR=100000
BACKTEST_FEE_BPS=5
BACKTEST_POSITION_LIMIT_SHARES=1000
BACKTEST_TRADE_SHARES=10

# Data providers
STOOQ_ENABLED=true
EOD_API_TOKEN=
RECONCILE_DIFF_THRESHOLD_BPS=10

# UI chart backend (streamlit | plotly)
# FUNTRADE_CHART_BACKEND=streamlit
